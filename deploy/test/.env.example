# Docker deployment
LING_DEPLOY_ROOT=../data/test
LING_HOME_PORT=32079
LING_ADMIN_PORT=32081
LING_ADMIN_API_BASE_URL=/ling-api

# External MySQL
LING_MYSQL_HOST=host.docker.internal
LING_MYSQL_USER=ling
LING_MYSQL_PASSWORD=change-me
LING_MYSQL_DATABASE=ling_test

# External Redis
LING_REDIS_HOST=host.docker.internal
LING_REDIS_PASSWORD=change-me

# Auth and login
LING_JWT_SECRET=replace-with-at-least-32-byte-secret
LING_SMS_ACCESS_KEY_ID=
LING_SMS_ACCESS_KEY_SECRET=
LING_SMS_SIGN_NAME=
LING_SMS_TEMPLATE_CODE=
LING_WECHAT_APP_ID=
LING_WECHAT_APP_SECRET=
LING_ADMIN_PHONE_WHITELIST=
LING_ADMIN_TOKEN_EXPIRE_MINUTES=43200

# Calendar integrations
LING_FEISHU_APP_ID=
LING_FEISHU_APP_SECRET=
LING_DINGTALK_CLIENT_ID=
LING_DINGTALK_CLIENT_SECRET=

# Object storage and Aliyun services
LING_S3_BUCKET=
LING_S3_ACCESS_KEY_ID=
LING_S3_ACCESS_KEY_SECRET=
LING_S3_PUBLIC_BASE_URL=
LING_PNS_ACCESS_KEY_ID=
LING_PNS_ACCESS_KEY_SECRET=
LING_EML_ACCESS_KEY_ID=
LING_EML_ACCESS_KEY_SECRET=
LING_EML_ACCOUNT_NAME=
LING_EML_TEMPLATE_ID=

# Sage Agent
LING_SAGE_API_URL=http://host.docker.internal:30050/api/chat

# Amap
LING_AMAP_WEB_KEY=

# Qwen Image
DASHSCOPE_API_KEY=

# Web Search
LING_BIGMODEL_API_KEY=

# APNs
LING_APNS_TEAM_ID=
LING_APNS_KEY_ID=
LING_APNS_AUTH_KEY=

# Mobile release gate
LING_MIN_IOS_VERSION=1.0.2+2026060101
